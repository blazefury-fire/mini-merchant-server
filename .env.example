# Template for .env — copy to .env and fill in real values.
# `cp .env.example .env`

# --- Datasource (PostgreSQL) ---
DB_URL=jdbc:postgresql://localhost:5432/mini_merchant_db
DB_USERNAME=admin
DB_PASSWORD=abc123
DB_DRIVER_CLASS_NAME=org.postgresql.Driver

# --- JPA / Flyway ---
JPA_DDL_AUTO=validate
FLYWAY_ENABLED=true

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PAYMENT_COMPLETED=payment-completed

# --- JWT ---
JWT_SECRET=change-me-please-use-a-long-random-secret-of-at-least-32-bytes
JWT_ACCESS_TOKEN_TTL_MINUTES=600000000
JWT_REFRESH_TOKEN_TTL_DAYS=7

# --- Rate limiting ---
RATELIMIT_PAYMENTS_LIMIT=10
RATELIMIT_PAYMENTS_WINDOW_SECONDS=60
